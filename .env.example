# Шаблон файла окружения
# Создайте копию как .env и заполните реальными значениями

# ===== БАЗА ДАННЫХ =====
# Для локального запуска
DATABASE_URL=postgresql://postgres:your_password@localhost/routsol

# Для Docker (используется автоматически в docker-compose)
POSTGRES_DB=routsol
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ===== БЕЗОПАСНОСТЬ =====
# Секретный ключ Flask (сгенерируйте случайный ключ)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Настройки cookies
SESSION_COOKIE_SECURE=False  # True только для HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SECURE=False  # True только для HTTPS
REMEMBER_COOKIE_HTTPONLY=True

# ===== API КЛЮЧИ =====
# Яндекс Карты JavaScript API (получить на developer.tech.yandex.ru)
YANDEX_MAPS_KEY=your-yandex-maps-key-here

# Опциональные API для поиска мест
TWOGIS_API_KEY=your-2gis-api-key-here
YANDEX_API_KEY=your-yandex-search-api-key-here

# ===== ПРИЛОЖЕНИЕ =====
FLASK_ENV=production
FLASK_DEBUG=False
WEB_PORT=5000

# ===== RATE LIMITING =====
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100/hour

# ===== CORS (если нужно) =====
CORS_ORIGINS=https://yourdomain.com